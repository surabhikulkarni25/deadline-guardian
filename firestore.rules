rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
      
      // Allow another user to add/remove themselves from incomingRequests array, or just allow update to incomingRequests
      allow update: if request.auth != null && (request.auth.uid == userId || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['incomingRequests', 'outgoingRequests', 'friends']));
      
      match /chats/{chatId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      match /tasks/{taskId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      match /friendRequests/{requesterId} {
        // The receiver and the sender can read the request
        allow read: if request.auth != null && (request.auth.uid == userId || request.auth.uid == requesterId);
        // The sender can create a request in the target's subcollection
        allow create: if request.auth != null && request.auth.uid == requesterId;
        // The target user can delete the request
        allow delete: if request.auth != null && request.auth.uid == userId;
      }
      
      match /friends/{friendId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        // Both users need to be able to add each other to their subcollections
        allow create: if request.auth != null && (request.auth.uid == userId || request.auth.uid == friendId);
        allow delete: if request.auth != null && (request.auth.uid == userId || request.auth.uid == friendId);
      }
    }
  }
}
